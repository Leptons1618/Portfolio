---
import Badge from './Badge.astro';
interface Props {
  title: string; slug: string; summary: string; category: string;
  tags: string[]; stack: string[]; status: string; year: number;
  highlights: string[]; repoUrl: string; demoUrl?: string;
  caseStudySlug?: string; heroImage?: string; metrics?: Record<string, string>;
}
const { title, slug, summary, category, tags, stack, status, year, highlights, repoUrl, demoUrl, caseStudySlug, heroImage, metrics } = Astro.props;

const statusBadgeClass: Record<string, string> = {
  active: 'status-badge status-badge-active',
  stable: 'status-badge status-badge-stable',
  archived: 'status-badge status-badge-archived',
  wip: 'status-badge status-badge-wip',
};
const statusLabel: Record<string, string> = {
  active: 'Active',
  stable: 'Stable',
  archived: 'Archived',
  wip: 'In Progress',
};

// Category-based emoji icon
const categoryIcon: Record<string, string> = {
  'ml-cv': '🤖', 'ai-llm': '🧠', 'full-stack': '🌐',
  devtools: '🔧', systems: '⚙️', simulation: '🎲',
  featured: '⭐', other: '📦',
};
---
<article class="project-card reveal">
  <!-- Status badge — top-right corner -->
  <div class="pc-badge-row">
    <div class="pc-icon-title">
      <span class="proj-icon" aria-hidden="true">{categoryIcon[category] || '📦'}</span>
      <div>
        <div class="pc-category">{category}</div>
        <h3 class="card-title"><a href={`/projects/${slug}`}>{title}</a></h3>
      </div>
    </div>
    <span class={statusBadgeClass[status] || 'status-badge status-badge-stable'} aria-label={`Status: ${status}`}>
      {statusLabel[status] || status}
    </span>
  </div>

  {heroImage && (
    <div class="card-image">
      <img src={heroImage} alt={title} loading="lazy" />
      <div class="card-image-overlay"></div>
    </div>
  )}

  <p class="card-summary">{summary}</p>

  {metrics && Object.keys(metrics).length > 0 && (
    <div class="card-metrics-row">
      {Object.entries(metrics).map(([k, v]) => (
        <div class="metric-box">
          <span class="metric-box-val">{v}</span>
          <span class="metric-box-key">{k}</span>
        </div>
      ))}
    </div>
  )}

  {highlights.length > 0 && (
    <ul class="feature-list">
      {highlights.slice(0, 3).map(h => <li>{h}</li>)}
    </ul>
  )}

  <div class="card-stack">
    {stack.slice(0, 5).map(s => <span class="stack-chip">{s}</span>)}
  </div>

  <div class="card-tags">
    {tags.slice(0, 4).map(tag => <Badge text={tag} />)}
  </div>

  <div class="card-actions">
    <a href={`/projects/${slug}`} class="btn btn-primary btn-xs">Details</a>
    {caseStudySlug && (
      <a href={`/case-studies/${caseStudySlug}`} class="btn btn-cta btn-xs">
        Case Study →
      </a>
    )}
    <a href={repoUrl} class="btn btn-outline btn-xs" target="_blank" rel="noopener">Repo ↗</a>
    {demoUrl && (
      <a href={demoUrl} class="btn btn-outline btn-xs" target="_blank" rel="noopener">Demo ↗</a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex; flex-direction: column; gap: 0.85rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    overflow: hidden;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    box-shadow: var(--shadow-card);
  }
  .project-card::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: inherit; padding: 1px;
    background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
  }
  .project-card:hover::before { opacity: 1; }

  /* Header row: icon+title left, badge right */
  .pc-badge-row {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 0.75rem;
  }
  .pc-icon-title {
    display: flex; align-items: flex-start; gap: 0.75rem; min-width: 0;
  }
  .pc-category {
    font-size: 0.65rem; font-family: var(--font-mono);
    color: var(--color-accent); text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 0.2rem;
  }
  .card-title { font-size: 1.05rem; margin: 0; line-height: 1.3; }
  .card-title a { color: var(--color-text); text-decoration: none; transition: color 0.15s; }
  .card-title a:hover { color: var(--color-accent); }

  /* Image */
  .card-image { position: relative; overflow: hidden; height: 150px; border-radius: var(--radius-md); }
  .card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .project-card:hover .card-image img { transform: scale(1.05); }
  .card-image-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 50%, var(--color-card-bg) 100%);
  }

  .card-summary { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.55; margin: 0; }

  /* Metrics */
  .card-metrics-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  /* Stack & tags */
  .card-stack { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .stack-chip {
    font-size: 0.7rem; padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted); font-family: var(--font-mono);
    background: var(--color-bg-tertiary);
    transition: border-color 0.2s, color 0.2s;
  }
  .stack-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  /* Actions */
  .card-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; padding-top: 0.25rem; }
  .btn-xs { padding: 0.25rem 0.65rem; font-size: 0.75rem; }
  .btn-cta {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.25rem 0.75rem; font-size: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text-muted);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .btn-cta:hover {
    border-color: var(--color-accent); color: var(--color-accent);
    background: var(--color-card-bg);
  }
</style>
