---
---
<button id="theme-toggle" class="theme-btn" aria-label="Switch theme" title="Cycle science dark, science light, and aurora themes">
  <span id="theme-icon">⚗️</span>
  <span id="theme-label">Science Dark</span>
</button>

<script>
  const STORAGE_KEY = 'portfolio-theme';
  const html = document.documentElement;
  const themes = ['science-dark', 'science-light', 'aurora'] as const;
  type Theme = (typeof themes)[number];
  function getTheme(): string {
    const stored = localStorage.getItem(STORAGE_KEY);
    let normalized = stored || 'science-dark';
    if (stored === 'science') normalized = 'science-dark';
    if (stored === 'punk') normalized = 'aurora';
    return themes.includes(normalized as Theme) ? normalized : 'science-dark';
  }
  function getThemeMeta(theme: string) {
    if (theme === 'aurora') return { icon: '🌌', label: 'Aurora', ariaName: 'Aurora' };
    if (theme === 'science-light') return { icon: '🔬', label: 'Sci Light', ariaName: 'Science Light' };
    return { icon: '⚗️', label: 'Science Dark', ariaName: 'Science Dark' };
  }
  function applyTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    const meta = getThemeMeta(theme);
    const icon = document.getElementById('theme-icon');
    const label = document.getElementById('theme-label');
    const button = document.getElementById('theme-toggle');
    if (icon) icon.textContent = meta.icon;
    if (label) label.textContent = meta.label;
    if (button) button.setAttribute('aria-label', `Switch theme (currently ${meta.ariaName})`);
    localStorage.setItem(STORAGE_KEY, theme);
  }
  applyTheme(getTheme());
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme') || 'science-dark';
    const currentIndex = themes.indexOf(current as Theme);
    if (currentIndex === -1) {
      applyTheme('science-dark');
      return;
    }
    const next = themes[(currentIndex + 1) % themes.length];
    applyTheme(next);
  });
</script>

<style>
  .theme-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.35rem 0.75rem; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border); background: var(--color-bg-secondary);
    color: var(--color-text); font-size: 0.8rem; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .theme-btn:hover { border-color: var(--color-accent); background: var(--color-bg-tertiary); }
</style>
