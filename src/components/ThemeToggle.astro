---
---
<button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" title="Toggle science/punk theme">
  <span id="theme-icon">⚗</span>
  <span id="theme-label">Science</span>
</button>

<script>
  const STORAGE_KEY = 'portfolio-theme';
  const html = document.documentElement;
  function getTheme(): string { return localStorage.getItem(STORAGE_KEY) || 'science'; }
  function applyTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    const icon = document.getElementById('theme-icon');
    const label = document.getElementById('theme-label');
    if (icon) icon.textContent = theme === 'punk' ? '⚡' : '⚗';
    if (label) label.textContent = theme === 'punk' ? 'Punk' : 'Science';
    localStorage.setItem(STORAGE_KEY, theme);
  }
  applyTheme(getTheme());
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme') || 'science';
    applyTheme(current === 'science' ? 'punk' : 'science');
  });
</script>

<style>
  .theme-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.35rem 0.75rem; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border); background: var(--color-bg-secondary);
    color: var(--color-text); font-size: 0.8rem; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .theme-btn:hover { border-color: var(--color-accent); background: var(--color-bg-tertiary); }
</style>
