---
import ProjectCard from './ProjectCard.astro';
interface Props { projects: any[]; }
const { projects } = Astro.props;
---
<div class="project-grid">
  {projects.map(project => (
    <ProjectCard title={project.data.title} slug={project.data.slug} summary={project.data.summary} category={project.data.category} tags={project.data.tags} stack={project.data.stack} status={project.data.status} year={project.data.year} highlights={project.data.highlights} repoUrl={project.data.repoUrl} demoUrl={project.data.demoUrl} caseStudySlug={project.data.caseStudySlug} heroImage={project.data.heroImage} metrics={project.data.metrics} />
  ))}
</div>
<style>
  .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
</style>
