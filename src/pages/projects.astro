---
import PageLayout from '../layouts/PageLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const categories = [...new Set(allProjects.map(p => p.data.category))].filter(c => c !== 'other').sort();

const tagCounts: Record<string, number> = {};
allProjects.forEach(p => {
  p.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 16)
  .map(([tag]) => tag);

const projectsData = allProjects.map(p => ({
  title: p.data.title,
  slug: p.slug,
  summary: p.data.summary,
  category: p.data.category,
  tags: p.data.tags,
  stack: p.data.stack,
  status: p.data.status,
  year: p.data.year,
  repoUrl: p.data.repoUrl,
  demoUrl: p.data.demoUrl,
  caseStudySlug: p.data.caseStudySlug,
  featuredRank: p.data.featuredRank,
}));

const categoryIcon: Record<string, string> = {
  'ml-cv': '🤖', 'ai-llm': '🧠', 'full-stack': '🌐',
  devtools: '🔧', systems: '⚙️', simulation: '🎲',
  featured: '⭐', other: '📦',
};

const statusBadgeClass: Record<string, string> = {
  active: 'status-badge status-badge-active',
  stable: 'status-badge status-badge-stable',
  archived: 'status-badge status-badge-archived',
  wip: 'status-badge status-badge-wip',
};
const statusLabel: Record<string, string> = {
  active: 'Active', stable: 'Stable', archived: 'Archived', wip: 'In Progress',
};
---
<PageLayout title="Projects" description="All projects — filterable by category, tag, and stack.">
  <div class="container">
    <div class="page-header">
      <h1>Project Library</h1>
      <p class="page-desc">All projects, filterable by category and tag.</p>
    </div>

    <FilterBar categories={categories} topTags={topTags} />

    <div id="results-count" class="results-count"></div>
    <div class="project-grid" id="project-grid">
      {projectsData.map(project => (
        <article
          class="project-card"
          data-title={project.title.toLowerCase()}
          data-summary={project.summary.toLowerCase()}
          data-category={project.category}
          data-tags={project.tags.join(',')}
          data-year={project.year}
          data-featured-rank={project.featuredRank ?? 9999}
        >
          <!-- Icon + title row with badge -->
          <div class="pc-header">
            <div class="pc-icon-title">
              <span class="proj-icon" aria-hidden="true">{categoryIcon[project.category] || '📦'}</span>
              <div>
                <div class="pc-category-label">{project.category}</div>
                <h3 class="card-title"><a href={`/projects/${project.slug}`}>{project.title}</a></h3>
              </div>
            </div>
            <span class={statusBadgeClass[project.status] || 'status-badge status-badge-stable'} aria-label={`Status: ${project.status}`}>
              {statusLabel[project.status] || project.status}
            </span>
          </div>
          <p class="card-summary">{project.summary}</p>
          <div class="card-tags">
            {project.tags.slice(0, 4).map(tag => (
              <span class="badge">{tag}</span>
            ))}
          </div>
          <div class="card-stack">
            {project.stack.slice(0, 5).map(s => (
              <span class="stack-chip">{s}</span>
            ))}
          </div>
          <div class="card-actions">
            <a href={`/projects/${project.slug}`} class="btn btn-primary btn-xs">Details</a>
            {project.caseStudySlug && (
              <a href={`/case-studies/${project.caseStudySlug}`} class="btn btn-outline btn-xs">Case Study →</a>
            )}
            <a href={project.repoUrl} class="btn btn-outline btn-xs" target="_blank" rel="noopener">Repo ↗</a>
            {project.demoUrl && (
              <a href={project.demoUrl} class="btn btn-outline btn-xs" target="_blank" rel="noopener">Demo ↗</a>
            )}
          </div>
        </article>
      ))}
    </div>
    <p id="no-results" class="no-results hidden">No projects match your filters.</p>
  </div>
</PageLayout>

<script>
  const grid = document.getElementById('project-grid')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.project-card'));
  const searchInput = document.getElementById('filter-search') as HTMLInputElement;
  const sortSelect = document.getElementById('filter-sort') as HTMLSelectElement;
  const categoryChips = document.querySelectorAll<HTMLElement>('[data-filter="category"]');
  const tagChips = document.querySelectorAll<HTMLElement>('[data-filter="tag"]');
  const noResults = document.getElementById('no-results')!;
  const resultsCount = document.getElementById('results-count')!;

  let activeCategory = '';
  let activeTags: string[] = [];
  let query = '';
  let sort = 'featured';

  function syncFromURL() {
    const params = new URLSearchParams(window.location.search);
    query = params.get('q') || '';
    activeCategory = params.get('category') || '';
    activeTags = params.get('tags')?.split(',').filter(Boolean) || [];
    sort = params.get('sort') || 'featured';
    if (searchInput) searchInput.value = query;
    if (sortSelect) sortSelect.value = sort;
  }

  function updateURL() {
    const params = new URLSearchParams();
    if (query) params.set('q', query);
    if (activeCategory) params.set('category', activeCategory);
    if (activeTags.length) params.set('tags', activeTags.join(','));
    if (sort !== 'featured') params.set('sort', sort);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
  }

  function applyFilters() {
    let visible: HTMLElement[] = [];
    for (const card of cards) {
      const title = card.dataset.title || '';
      const summary = card.dataset.summary || '';
      const category = card.dataset.category || '';
      const tags = card.dataset.tags?.split(',') || [];
      const q = query.toLowerCase();
      const matchesQ = !q || title.includes(q) || summary.includes(q) || tags.some(t => t.includes(q));
      const matchesCat = !activeCategory || category === activeCategory;
      const matchesTags = activeTags.length === 0 || activeTags.every(t => tags.includes(t));
      if (matchesQ && matchesCat && matchesTags) {
        card.style.display = '';
        visible.push(card);
      } else {
        card.style.display = 'none';
      }
    }
    visible.sort((a, b) => {
      if (sort === 'newest') return parseInt(b.dataset.year || '0') - parseInt(a.dataset.year || '0');
      if (sort === 'az') return (a.dataset.title || '').localeCompare(b.dataset.title || '');
      return parseInt(a.dataset.featuredRank || '9999') - parseInt(b.dataset.featuredRank || '9999');
    });
    visible.forEach(card => grid.appendChild(card));
    noResults.classList.toggle('hidden', visible.length > 0);
    resultsCount.textContent = `${visible.length} project${visible.length === 1 ? '' : 's'}`;
    categoryChips.forEach(chip => chip.classList.toggle('chip-active', chip.dataset.value === activeCategory));
    tagChips.forEach(chip => chip.classList.toggle('chip-tag-active', activeTags.includes(chip.dataset.value || '')));
  }

  syncFromURL();
  searchInput?.addEventListener('input', e => { query = (e.target as HTMLInputElement).value; updateURL(); applyFilters(); });
  sortSelect?.addEventListener('change', e => { sort = (e.target as HTMLSelectElement).value; updateURL(); applyFilters(); });
  categoryChips.forEach(chip => chip.addEventListener('click', () => {
    activeCategory = chip.dataset.value === activeCategory ? '' : (chip.dataset.value || '');
    updateURL(); applyFilters();
  }));
  tagChips.forEach(chip => chip.addEventListener('click', () => {
    const val = chip.dataset.value || '';
    activeTags = activeTags.includes(val) ? activeTags.filter(t => t !== val) : [...activeTags, val];
    updateURL(); applyFilters();
  }));
  applyFilters();
</script>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .page-header { padding: 3rem 0 2rem; }
  .page-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .page-desc { color: var(--color-text-muted); }
  .results-count { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1rem; }
  .no-results { text-align: center; padding: 3rem; color: var(--color-text-muted); }
  .hidden { display: none; }

  /* Project grid */
  .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }

  /* Project card — vibrant style */
  .project-card {
    display: flex; flex-direction: column; gap: 0.75rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    position: relative; overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    box-shadow: var(--shadow-card);
  }
  .project-card::before {
    content: '';
    position: absolute; inset: 0;
    border-radius: inherit; padding: 1px;
    background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .project-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); border-color: var(--color-accent); }
  .project-card:hover::before { opacity: 1; }

  /* Header row */
  .pc-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; }
  .pc-icon-title { display: flex; align-items: flex-start; gap: 0.7rem; min-width: 0; }
  .pc-category-label { font-size: 0.65rem; font-family: var(--font-mono); color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.2rem; }
  .card-title { font-size: 1rem; margin: 0; line-height: 1.3; }
  .card-title a { color: var(--color-text); text-decoration: none; transition: color 0.15s; }
  .card-title a:hover { color: var(--color-accent); }
  .card-summary { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }

  /* Tags and stack */
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .card-stack { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .stack-chip {
    font-size: 0.7rem; padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted); font-family: var(--font-mono);
    background: var(--color-bg-tertiary);
    transition: border-color 0.2s, color 0.2s;
  }
  .stack-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* Actions */
  .card-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; padding-top: 0.25rem; }
  .btn-xs { padding: 0.25rem 0.6rem; font-size: 0.75rem; }

  @media (max-width: 640px) {
    .project-grid { grid-template-columns: 1fr; }
  }
</style>
